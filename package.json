{
  "name": "my-local-info",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run check:choice-quality && npm run test:choice-single-pick && next build",
    "prebuild": "node scripts/build-search-index.js",
    "verify:data": "node scripts/verify-data-json.js",
    "postbuild": "node scripts/generate-sitemap.js && node scripts/generate-search-index.js",
    "generate:blog": "node scripts/generate-blog-post.js",
    "generate:blog:latest": "node scripts/run-blog-latest.js",
    "generate:choice": "node scripts/generate-choice-post.js",
    "generate:choice:latest": "node scripts/run-choice-latest.js",
    "generate:choice:auto": "node scripts/generate-choice-posts-auto.js",
    "check:choice-quality": "node scripts/validate-choice-quality.js",
    "test:choice-single-pick": "node scripts/test-choice-single-pick.js",
    "collect:subsidy": "node scripts/collect-subsidy.js",
    "collect:life-restaurants": "node scripts/collect-life-restaurants.mjs",
    "generate:life-restaurant-posts": "node scripts/generate-life-restaurant-posts.mjs",
    "start": "next start",
    "lint": "eslint",
    "check:worktree": "powershell -ExecutionPolicy Bypass -File scripts/check-worktree-safety.ps1",
    "check:worktree:commit": "powershell -ExecutionPolicy Bypass -File scripts/check-worktree-safety.ps1 -MaxChanged 30",
    "check:worktree:strict": "powershell -ExecutionPolicy Bypass -File scripts/check-worktree-safety.ps1 -FailOnDirty -MaxChanged 10",
    "check:worktree:repair-hooks": "powershell -ExecutionPolicy Bypass -File scripts/check-worktree-safety.ps1 -RepairHooks",
    "hooks:install": "powershell -ExecutionPolicy Bypass -File scripts/install-git-hooks.ps1",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@supabase/supabase-js": "^2.102.1",
    "@tailwindcss/typography": "^0.5.19",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "next-sitemap": "^4.2.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "next": "^16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.87.0"
  }
}
